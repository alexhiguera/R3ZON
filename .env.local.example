# ─── Supabase ─────────────────────────────────────────────────────────────────
# URL del proyecto (visible en Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Clave publicable (anon key). Se puede exponer en el cliente.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Service-role key — acceso total sin RLS. NUNCA exponer al cliente.
# Solo se usa en rutas API server-side (webhooks, sync).
SUPABASE_SERVICE_ROLE_KEY=

# Para migraciones con Supabase CLI (no necesaria en runtime)
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
# Crear en console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL HTTPS pública donde Google enviará los push notifications del watch channel.
# En desarrollo usa un túnel: cloudflared tunnel --url http://localhost:3000
# En producción: https://tu-dominio.com
GOOGLE_WEBHOOK_URL=https://your-tunnel.trycloudflare.com/api/integrations/google/webhook

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Secret key del panel Stripe (Developers → API keys). Nunca exponer.
STRIPE_SECRET_KEY=sk_test_

# Secret del webhook (Stripe Dashboard → Developers → Webhooks → Signing secret)
# En desarrollo: stripe listen --forward-to localhost:3000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_

# IDs de los precios (Products → tu producto → Pricing)
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_BUSINESS=price_

# ─── App ──────────────────────────────────────────────────────────────────────
# URL pública de la aplicación (sin trailing slash). Usada para redirects OAuth.
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# ─── Supabase: clave maestra pgcrypto (NO en .env, en la BD) ─────────────────
# Los tokens de Google se almacenan cifrados con pgp_sym_encrypt usando una
# clave maestra definida como GUC en Postgres (NUNCA en .env del frontend):
#
#   1) Generar una clave aleatoria fuerte:
#        openssl rand -base64 48
#
#   2) En Supabase → Project Settings → Database → Custom Postgres Config,
#      añadir:
#        app.config_master_key = '<la-clave-generada>'
#
#   3) Reiniciar el proyecto para que la GUC se cargue.
#
# Rotación: si se rota la clave, hay que re-cifrar las filas existentes de
# google_connections con la nueva clave (script ad-hoc). No se puede recuperar
# tokens sin la clave anterior — guardarla en gestor de secretos (1Password,
# Bitwarden o Vercel Secrets) además de en Supabase.

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret aleatorio para autorizar el cron de renovación de watch channels.
# Generar con: openssl rand -base64 32
CRON_SECRET=

# ─── Solo desarrollo (eliminar en producción) ─────────────────────────────────
# Botón de login rápido en la pantalla de login (solo visible si NODE_ENV=development)
NEXT_PUBLIC_DEV_EMAIL=dev@ejemplo.com
NEXT_PUBLIC_DEV_PASSWORD=devpassword123
