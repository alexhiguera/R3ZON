# Supabase — públicas
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Privadas (sin NEXT_PUBLIC_) — solo para CLI/migraciones
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

NEXT_PUBLIC_KEY_PEPPER=change-me

# Service-role para path admin (webhooks, sync server-side). NUNCA exponer.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Calendar / Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL HTTPS pública del webhook (en dev: usar túnel cloudflared/ngrok).
GOOGLE_WEBHOOK_URL=https://your-tunnel.trycloudflare.com/api/integrations/google/webhook

# Secret aleatorio para autorizar el cron de renovación de watch channels.
# Generar con: openssl rand -base64 32
CRON_SECRET=
